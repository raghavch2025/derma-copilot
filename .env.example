# =============================================================================
# DERMA-COPILOT — Environment Variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# =============================================================================

# ───── Supabase ─────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                # server-only, never client
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...            # safe for client

# ───── Twilio ─────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pre-approved Content Template SIDs (from Twilio Console / Content API)
TPL_INQUIRY_TO_BOOKING=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TPL_DAILY_MED_REMINDER=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TPL_PRE_PROCEDURE_PREP=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ───── Application ─────
PUBLIC_BASE_URL=https://your-app.vercel.app
CRON_SECRET=generate-a-long-random-string-here
INTERNAL_PIPELINE_TOKEN=generate-another-long-random-string

# ───── LLM Provider (choose one) ─────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
